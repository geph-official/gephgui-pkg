#!/bin/bash
#
# Runs as root before the payload is written. On an upgrade, stop the currently
# running manager so its binary can be replaced cleanly (macOS lets you unlink a
# running Mach-O, but stopping first avoids the old code lingering until the
# postinstall kickstart). No-op on a first install.

set -e

launchctl bootout system/io.geph.manager 2>/dev/null || true
# Also boot out the pre-rename label, in case an older dev build is installed.
launchctl bootout system/io.geph.daemon 2>/dev/null || true

# Stop the old GUI so the next launch runs the newly installed binary. Otherwise
# it keeps the port-5678 single-instance lock and a new launch merely asks that
# old process to show its window.
pkill -x gephgui-wry 2>/dev/null || true

# Kill any leftover engine processes. The manager booted out above is the only
# thing that legitimately runs geph5-client, so anything still alive here is a
# stray: a 5.7.x-era (.dmg) client spawned directly by the old GUI, or an
# orphan from a killed manager. Survivors keep the proxy ports (9909/9910/12223)
# bound, which makes every post-upgrade connect die with "address already in
# use".
pkill -x geph5-client 2>/dev/null || true

exit 0
